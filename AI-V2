        int cold = field.get_or_create("cold", "word");
        int burn = field.get_or_create("burn", "word");

        std::vector<int> ctx = field.decompose_sentence("fire");

        // Try a good jump (fire -> burn, related to context)
        auto pj1 = field.try_jump(fire, burn, 0.5, {fire}, ctx);
        std::vector<int> test_out = {fire, burn};
        if (field.validate_jump(pj1, test_out, ctx)) {
            field.commit_jump(pj1);
        } else {
            field.rollback_jump(pj1);
        }

        // Try a bad jump (fire -> cold, contradicts context)
        auto pj2 = field.try_jump(fire, cold, 0.5, {fire}, ctx);
        std::vector<int> test_out2 = {fire, cold};
        if (field.validate_jump(pj2, test_out2, ctx)) {
            field.commit_jump(pj2);
