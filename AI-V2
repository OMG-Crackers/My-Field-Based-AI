// ============================================================
// INFINITE FIELD AI
// ============================================================
// Core concept: Every content fragment IS a dimension.
// No fixed vector size. The structure grows with knowledge.
// Three primitives: Deposit, Overlap, Direction
// ============================================================

// --- Dimension ---
// Each unique content fragment (letter, token, word, binary, etc.)
// is its own dimension in the field.
struct Dimension {
    int id;
    std::string content;
    std::string type;
    double activation;      // current activation level
    double baseline;         // running average — how active this word USUALLY is
    double personality;

    std::unordered_map<int, double> connections;

    // Direct routing
    std::unordered_map<int, double> next_words;
    std::unordered_map<int, double> prev_words;
    double start_weight;

    int deposit_count;

    // Gates
    double input_gate;
    double output_gate;
    double think_gate;
    double forget_gate;
    double input_momentum;
    double output_momentum;
    double think_momentum;

    // Signal = activation - baseline
    // What's unique about RIGHT NOW vs what's normal
    double signal() const {
        return activation - baseline;
    }

    Dimension()
        : id(-1), activation(0.0), baseline(0.0), personality(0.0),
          start_weight(0.0), deposit_count(0),
          input_gate(1.0), output_gate(1.0), think_gate(1.0), forget_gate(0.1),
          input_momentum(0.0), output_momentum(0.0), think_momentum(0.0) {}

    Dimension(int id_, const std::string& content_, const std::string& type_)
        : id(id_), content(content_), type(type_),
          activation(0.0), baseline(0.0), personality(0.0),
          start_weight(0.0), deposit_count(0),
          input_gate(1.0), output_gate(1.0), think_gate(1.0), forget_gate(0.1),
          input_momentum(0.0), output_momentum(0.0), think_momentum(0.0) {}
};

// --- Connection Key ---
struct PairHash {
    size_t operator()(const std::pair<int,int>& p) const {
        return std::hash<long long>()(((long long)p.first << 32) | p.second);
    }
};

// ============================================================
// INFINITE FIELD
// ============================================================
class InfiniteField {
public:
    // All dimensions in the field
    std::unordered_map<int, Dimension> dimensions;

    // Lookup: "type:content" -> dimension id
    std::unordered_map<std::string, int> lookup;

    // Conversation pairs: input_dim_ids -> response_dim_ids
    // This is how the system learns what to say back
    struct ConversationLink {
        std::vector<int> input_dims;
        std::vector<int> response_dims;
        double strength;
    };
    std::vector<ConversationLink> conversation_memory;

    // Personality dimensions - persistently weighted
    std::vector<int> personality_dims;

    int next_id;
    double deposit_sigma;    // Gaussian spread for deposits
    double connection_decay; // How fast connection weight falls with distance
    double traversal_threshold; // Minimum similarity to stop traversal
    double jump_threshold;   // Minimum overlap to allow a dimensional jump
    int jump_count;          // Track how many jumps the system has made

    InfiniteField()
        : next_id(0), deposit_sigma(1.0),
          connection_decay(0.5), traversal_threshold(0.3),
          jump_threshold(0.15), jump_count(0),
          good_jumps(0), bad_jumps(0), thought_cycles(0) {}

    // ----------------------------------------------------------
    // DIMENSION MANAGEMENT
    // ----------------------------------------------------------

    // Find or create a dimension for a content fragment
    int get_or_create(const std::string& content, const std::string& type) {
        std::string key = type + ":" + content;
        auto it = lookup.find(key);
        if (it != lookup.end()) {
            return it->second;
        }
        int id = next_id++;
        dimensions[id] = Dimension(id, content, type);
        lookup[key] = id;
        return id;
    }

    // Check if dimension exists
    bool exists(const std::string& content, const std::string& type) const {
        std::string key = type + ":" + content;
        return lookup.find(key) != lookup.end();
    }

    // Get dimension by id
    Dimension& dim(int id) {
        return dimensions[id];
    }

    const Dimension& dim(int id) const {
        return dimensions.at(id);
    }

    // ----------------------------------------------------------
    // DECOMPOSE: Break input into multi-level dimensions
    // ----------------------------------------------------------
    // "the" becomes:
    //   word:the
    //   letter:t, letter:h, letter:e
    //   token:t + token:he, token:th + token:e
    //   binary representation
    // All created dimensions get connected to each other
    // ----------------------------------------------------------

    std::vector<int> decompose(const std::string& input) {
        std::vector<int> created;
        if (input.empty()) return created;

        // Level 1: The whole input as a word
        int word_id = get_or_create(input, "word");
        created.push_back(word_id);

        // Level 2: Individual letters
        for (size_t i = 0; i < input.size(); i++) {
            std::string letter(1, input[i]);
            int letter_id = get_or_create(letter, "letter");
            created.push_back(letter_id);
        }

        // Level 3: Token splits (all possible 2-part splits)
        if (input.size() >= 2) {
            for (size_t split = 1; split < input.size(); split++) {
                std::string left = input.substr(0, split);
                std::string right = input.substr(split);
                int left_id = get_or_create(left, "token");
                int right_id = get_or_create(right, "token");
                created.push_back(left_id);
                created.push_back(right_id);
            }
        }

        // Level 4: Binary representation of the whole word
        std::string binary;
        for (char c : input) {
            for (int bit = 7; bit >= 0; bit--) {
                binary += ((c >> bit) & 1) ? '1' : '0';
            }
        }
        int binary_id = get_or_create(binary, "binary");
        created.push_back(binary_id);

        // Remove duplicates
        std::sort(created.begin(), created.end());
        created.erase(std::unique(created.begin(), created.end()), created.end());

        // Connect all created dimensions to each other (co-occurrence)
        for (size_t i = 0; i < created.size(); i++) {
            for (size_t j = i + 1; j < created.size(); j++) {
                connect(created[i], created[j], 1.0);
            }
        }

        return created;
    }

    // Decompose a full sentence into words, then decompose each word,
    // and connect sequential words
    std::vector<int> decompose_sentence(const std::string& sentence) {
        std::vector<int> all_dims;
        std::vector<std::string> words = split_words(sentence);

        // Create phrase dimension for the whole sentence
        std::string lower_sentence = to_lower(sentence);
        int phrase_id = get_or_create(lower_sentence, "phrase");
        all_dims.push_back(phrase_id);

        std::vector<int> word_dims;
        for (const auto& word : words) {
            std::string lower_word = to_lower(word);
            if (lower_word.empty()) continue;

            std::vector<int> dims = decompose(lower_word);
            all_dims.insert(all_dims.end(), dims.begin(), dims.end());

            // Track the word-level dimension for sequential connections
            std::string key = "word:" + lower_word;
            auto it = lookup.find(key);
            if (it != lookup.end()) {
                word_dims.push_back(it->second);
            }
        }

        // Connect sequential words (word order matters)
        for (size_t i = 0; i + 1 < word_dims.size(); i++) {
            connect(word_dims[i], word_dims[i + 1], 0.8);

            // DIRECT ROUTING: wire next/prev directly on the word dims
            // This is the axon — no scanning needed to find what follows
            auto& from_nw = dimensions[word_dims[i]].next_words;
            if (from_nw.find(word_dims[i + 1]) != from_nw.end()) {
                from_nw[word_dims[i + 1]] += 1.0 / (1.0 + from_nw[word_dims[i + 1]]);
            } else {
                from_nw[word_dims[i + 1]] = 1.0;
            }

            auto& to_pw = dimensions[word_dims[i + 1]].prev_words;
            if (to_pw.find(word_dims[i]) != to_pw.end()) {
                to_pw[word_dims[i]] += 1.0 / (1.0 + to_pw[word_dims[i]]);
            } else {
                to_pw[word_dims[i]] = 1.0;
            }

            // Still create seq dim for structural record
            std::string seq_content = dimensions[word_dims[i]].content +
                                      "->" + dimensions[word_dims[i + 1]].content;
            int seq_id = get_or_create(seq_content, "seq");
            all_dims.push_back(seq_id);

            connect(seq_id, word_dims[i], 1.5);
            connect(seq_id, word_dims[i + 1], 1.5);

            if (i > 0) {
                std::string prev_seq = dimensions[word_dims[i - 1]].content +
                                       "->" + dimensions[word_dims[i]].content;
                if (exists(prev_seq, "seq")) {
                    int prev_seq_id = lookup["seq:" + prev_seq];
                    connect(prev_seq_id, seq_id, 1.2);
                }
            }
        }

        // Mark sentence start words — directly on the dimension
        if (!word_dims.empty()) {
            dimensions[word_dims[0]].start_weight += 1.0;

            // Still create seq dim for structural record
            std::string start_content = "START->" + dimensions[word_dims[0]].content;
            int start_id = get_or_create(start_content, "seq");
            connect(start_id, word_dims[0], 1.5);
            all_dims.push_back(start_id);

            if (word_dims.size() >= 2) {
                std::string first_seq = dimensions[word_dims[0]].content +
                                        "->" + dimensions[word_dims[1]].content;
                if (exists(first_seq, "seq")) {
                    connect(start_id, lookup["seq:" + first_seq], 1.2);
                }
            }
        }

        // Connect phrase to all its word dimensions
        for (int wd : word_dims) {
            connect(phrase_id, wd, 1.0);
        }

        // Remove duplicates
        std::sort(all_dims.begin(), all_dims.end());
        all_dims.erase(std::unique(all_dims.begin(), all_dims.end()), all_dims.end());

        return all_dims;
    }

    // ----------------------------------------------------------
    // PRIMITIVE 1: DEPOSIT (Gaussian)
    // ----------------------------------------------------------
    // Activate a dimension and spread activation to connected
    // dimensions with Gaussian falloff
    // ----------------------------------------------------------

    void deposit(int dim_id, double strength) {
        if (dimensions.find(dim_id) == dimensions.end()) return;

        Dimension& d = dimensions[dim_id];
        // Input gate controls how much deposit is accepted
        double gated_strength = strength * d.input_gate;
        d.activation += gated_strength;
        d.deposit_count++;

        // Spread to connected dimensions with Gaussian falloff
        for (auto& [conn_id, weight] : d.connections) {
            if (dimensions.find(conn_id) == dimensions.end()) continue;
            Dimension& target = dimensions[conn_id];
            double distance = 1.0 / (weight + 0.001);
            // Target's input gate also modulates incoming spread
            double spread = gated_strength * weight *
                           gaussian(distance, deposit_sigma) * target.input_gate;
            target.activation += spread;
        }
    }

    // Deposit across a set of dimensions (from decomposition)
    void deposit_set(const std::vector<int>& dim_ids, double strength) {
        for (int id : dim_ids) {
            deposit(id, strength);
        }
    }

    // Apply forget gates: decay activation across the field
    // Call this periodically to let transient activations fade
    void decay_activations() {
        for (auto& [id, d] : dimensions) {
            d.activation *= (1.0 - d.forget_gate * 0.1);
            if (d.activation < 0.001) d.activation = 0.0;
        }
    }

    // Update baselines: absorb current activation into the running average
    // Call after each learning cycle. Baseline slowly tracks what's "normal"
    // so signal() reveals what's unique about the current moment.
    void update_baselines() {
        for (auto& [id, d] : dimensions) {
            // Exponential moving average: 95% old baseline, 5% current
            d.baseline = d.baseline * 0.95 + d.activation * 0.05;
        }
    }

    // ----------------------------------------------------------
    // GATE LEARNING
    // ----------------------------------------------------------
    // Gates learn from feedback. When a dimension contributes to
    // a successful outcome, its relevant gate opens. When it
    // contributes to failure or noise, the gate closes.
    // Learning rate controls how fast gates adapt.
    // ----------------------------------------------------------

    static constexpr double gate_learn_rate = 0.05;
    static constexpr double gate_momentum_decay = 0.9;

    // Reinforce: this dimension was useful in this context
    void gate_reinforce(int dim_id, const std::string& gate_type, double signal) {
        if (dimensions.find(dim_id) == dimensions.end()) return;
        Dimension& d = dimensions[dim_id];

        double adjustment = signal * gate_learn_rate;

        if (gate_type == "input") {
            d.input_momentum = d.input_momentum * gate_momentum_decay + adjustment;
            d.input_gate += d.input_momentum;
        } else if (gate_type == "output") {
            d.output_momentum = d.output_momentum * gate_momentum_decay + adjustment;
            d.output_gate += d.output_momentum;
        } else if (gate_type == "think") {
            d.think_momentum = d.think_momentum * gate_momentum_decay + adjustment;
            d.think_gate += d.think_momentum;
        } else if (gate_type == "forget") {
            d.forget_gate += adjustment;
        }

        // Clamp all gates to [0.01, 1.0]
        d.input_gate = std::max(0.01, std::min(1.0, d.input_gate));
        d.output_gate = std::max(0.01, std::min(1.0, d.output_gate));
        d.think_gate = std::max(0.01, std::min(1.0, d.think_gate));
        d.forget_gate = std::max(0.01, std::min(1.0, d.forget_gate));
    }

    // Batch reinforce along a path (used after successful thought/response)
    void gate_reinforce_path(const std::vector<int>& path,
                            const std::string& gate_type, double signal) {
        for (int id : path) {
            gate_reinforce(id, gate_type, signal);
        }
    }

    // ----------------------------------------------------------
    // PRIMITIVE 2: OVERLAP
    // ----------------------------------------------------------
    // Measure how much two sets of dimensions share structure.
    // Not just direct matches, but shared connections too.
    // ----------------------------------------------------------

    double overlap(const std::vector<int>& set_a, const std::vector<int>& set_b) {
        if (set_a.empty() || set_b.empty()) return 0.0;

        // Direct overlap: how many dimensions appear in both sets
        std::unordered_set<int> a_set(set_a.begin(), set_a.end());
        std::unordered_set<int> b_set(set_b.begin(), set_b.end());

        double direct = 0.0;
        for (int id : a_set) {
            if (b_set.count(id)) {
                direct += 1.0;
            }
        }

        // Connection overlap: how many of A's connections point to B
        double connection_overlap = 0.0;
        int connection_count = 0;
        for (int a_id : set_a) {
            if (dimensions.find(a_id) == dimensions.end()) continue;
            for (auto& [conn_id, weight] : dimensions[a_id].connections) {
                connection_count++;
                if (b_set.count(conn_id)) {
                    connection_overlap += weight;
                }
            }
        }

        // Normalize
        double max_possible = static_cast<double>(
            std::max(set_a.size(), set_b.size()));
        double direct_score = direct / max_possible;
        double conn_score = (connection_count > 0)
            ? connection_overlap / connection_count : 0.0;

        // Combined score: direct matches weighted more than connection matches
        return 0.6 * direct_score + 0.4 * conn_score;
    }

    // Find the best matching conversation memory for input
    int find_best_match(const std::vector<int>& input_dims) {
        int best_idx = -1;
        double best_score = -1.0;

        for (size_t i = 0; i < conversation_memory.size(); i++) {
            double score = overlap(input_dims, conversation_memory[i].input_dims);
            score *= conversation_memory[i].strength;
            if (score > best_score) {
                best_score = score;
                best_idx = static_cast<int>(i);
            }
        }

        return (best_score > traversal_threshold) ? best_idx : -1;
    }

    // ----------------------------------------------------------
    // PRIMITIVE 3: DIRECTION (Traversal)
    // ----------------------------------------------------------
    // From a starting set of dimensions, find which direction
    // to traverse, biased by personality weights.
    // This is how the system generates responses instead of
    // just mirroring input.
    // ----------------------------------------------------------

    // Get the strongest connected dimensions from a starting point,
    // excluding the starting dimensions themselves
    std::vector<std::pair<int, double>> direction(
        const std::vector<int>& from_dims, int max_steps = 3)
    {
        std::unordered_set<int> visited(from_dims.begin(), from_dims.end());
        std::vector<std::pair<int, double>> frontier;

        // Initial frontier: all connections from starting dims
        for (int id : from_dims) {
            if (dimensions.find(id) == dimensions.end()) continue;
            for (auto& [conn_id, weight] : dimensions[id].connections) {
                if (visited.count(conn_id)) continue;

                // Apply personality bias
                double personality_boost = 0.0;
                if (dimensions.find(conn_id) != dimensions.end()) {
                    personality_boost = dimensions[conn_id].personality;
                }

                double score = weight + personality_boost * 0.5;

                // Signal: what's uniquely active, not just what's always on
                double sig = dimensions[conn_id].signal();
                score += std::max(0.0, sig) * 0.3;

                // Output gate
                score *= dimensions[conn_id].output_gate;

                frontier.push_back({conn_id, score});
            }
        }

        // Sort by score descending
        std::sort(frontier.begin(), frontier.end(),
            [](const auto& a, const auto& b) { return a.second > b.second; });

        // Optional: walk further steps from the top frontier nodes
        if (max_steps > 1 && !frontier.empty()) {
            int walk_count = std::min((int)frontier.size(), 3);
            for (int w = 0; w < walk_count; w++) {
                int next_id = frontier[w].first;
                visited.insert(next_id);

                if (dimensions.find(next_id) == dimensions.end()) continue;
                for (auto& [conn_id, weight] : dimensions[next_id].connections) {
                    if (visited.count(conn_id)) continue;

                    double score = weight * frontier[w].second * connection_decay;
                    score += dimensions[conn_id].personality * 0.3;

                    frontier.push_back({conn_id, score});
                    visited.insert(conn_id);
                }
            }

            // Re-sort after adding deeper connections
            std::sort(frontier.begin(), frontier.end(),
                [](const auto& a, const auto& b) { return a.second > b.second; });
        }

        return frontier;
    }

    // ----------------------------------------------------------
    // CONNECTIONS
    // ----------------------------------------------------------

    void connect(int id_a, int id_b, double weight) {
        if (id_a == id_b) return;
        if (dimensions.find(id_a) == dimensions.end()) return;
        if (dimensions.find(id_b) == dimensions.end()) return;

        // Strengthen existing connection or create new
        auto& conn_a = dimensions[id_a].connections;
        auto& conn_b = dimensions[id_b].connections;

        if (conn_a.find(id_b) != conn_a.end()) {
            // Strengthen: diminishing returns
            conn_a[id_b] += weight * (1.0 / (1.0 + conn_a[id_b]));
            conn_b[id_a] += weight * (1.0 / (1.0 + conn_b[id_a]));
        } else {
            conn_a[id_b] = weight;
            conn_b[id_a] = weight;
        }
    }

    // ----------------------------------------------------------
    // PERSONALITY
    // ----------------------------------------------------------

    void set_personality(const std::string& trait, double weight) {
        int id = get_or_create(trait, "meta");
        dimensions[id].personality = weight;
        personality_dims.push_back(id);

        // Connect personality to common response patterns
        // This biases traversal direction
    }

    // ----------------------------------------------------------
    // LEARNING: Teach the system conversation pairs
    // ----------------------------------------------------------

    void learn(const std::string& input, const std::string& response) {
        std::vector<int> input_dims = decompose_sentence(input);
        std::vector<int> response_dims = decompose_sentence(response);

        // Deposit on both
        deposit_set(input_dims, 1.0);
        deposit_set(response_dims, 1.0);

        // Create directional connections from input dims to response dims
        // These are weaker than internal connections but create the bridge
        // from recognition to generation
        for (int in_id : input_dims) {
            if (dimensions[in_id].type != "word") continue;
            for (int resp_id : response_dims) {
                if (dimensions[resp_id].type != "word") continue;
                connect(in_id, resp_id, 0.6);
            }
        }

        // Connect personality dims to response dims
        for (int p_id : personality_dims) {
            for (int resp_id : response_dims) {
                if (dimensions[resp_id].type == "word") {
                    connect(p_id, resp_id, 0.3);
                }
            }
        }

        // Store conversation pair
        ConversationLink link;
        link.input_dims = input_dims;
        link.response_dims = response_dims;
        link.strength = 1.0;
        conversation_memory.push_back(link);

        // Update baselines so signal() knows what's normal
        update_baselines();
    }

    // ----------------------------------------------------------
    // AUTO-FILL: Generate potential dimensions from existing ones
    // ----------------------------------------------------------

    std::vector<int> auto_fill(const std::string& partial) {
        std::vector<int> generated;
        std::string lower_partial = to_lower(partial);

        // Find all words that share letter dimensions with this partial
        for (auto& [key, id] : lookup) {
            if (key.substr(0, 5) != "word:") continue;
            std::string word = key.substr(5);
            if (word.size() <= lower_partial.size()) continue;
            if (word.substr(0, lower_partial.size()) == lower_partial) {
                generated.push_back(id);
            }
        }

        // Also check letter-level connections for possible completions
        std::vector<int> partial_dims = decompose(lower_partial);
        auto directions = direction(partial_dims, 1);

        for (auto& [dir_id, score] : directions) {
            if (dimensions[dir_id].type == "word" && score > 0.3) {
                generated.push_back(dir_id);
            }
        }

        // Remove duplicates
        std::sort(generated.begin(), generated.end());
        generated.erase(std::unique(generated.begin(), generated.end()),
                       generated.end());

        return generated;
    }

    // ----------------------------------------------------------
    // RESPOND: Process input and generate a response
    // ----------------------------------------------------------

    std::string respond(const std::string& input) {
        std::vector<int> input_dims = decompose_sentence(input);

        // Decay old activations so signal reflects THIS conversation
        decay_activations();

        // Fresh deposit on input dimensions
        deposit_set(input_dims, 2.0);

        // Strategy 1: Find best matching conversation memory
        int match_idx = find_best_match(input_dims);
        if (match_idx >= 0) {
            auto& matched = conversation_memory[match_idx];
            matched.strength += 0.1;

            auto& resp_dims = matched.response_dims;

            // Deposit on response dims too — primes signal for reconstruction
            deposit_set(resp_dims, 1.5);

            // Reconstruct with sequence chains
            std::string response = reconstruct_from_dims(resp_dims);

            // If response is too similar to input, use jump generation
            // to create something novel from fragments
            double sim = overlap(input_dims, resp_dims);
            if (sim > 0.7) {
                std::string jump_response = generate_with_jumps(
                    resp_dims, input_dims, 10);
                if (!jump_response.empty()) {
                    response = jump_response;
                }
            }

            if (!response.empty()) return response;
        }

        // Strategy 2: No conversation match - use jump generation
        // This is where novel responses come from: the system
        // jumps across learned fragments to build something new
        std::string jump_response = generate_with_jumps(
            input_dims, input_dims, 10);
        if (!jump_response.empty() && jump_response.length() > 2) {
            // Make sure we're not just echoing input back
            std::string lower_input = to_lower(input);
            std::string lower_response = to_lower(jump_response);
            // Strip to just words for comparison
            auto input_words_set = split_words(lower_input);
            auto resp_words = split_words(lower_response);

            // Remove response words that are in the input
            std::unordered_set<std::string> iw_set(
                input_words_set.begin(), input_words_set.end());
            std::string filtered;
            for (auto& rw : resp_words) {
                if (!iw_set.count(rw)) {
                    if (!filtered.empty()) filtered += " ";
                    filtered += rw;
                }
            }

            if (!filtered.empty()) {
                return filtered;
            } else if (resp_words.size() > input_words_set.size()) {
                return jump_response; // has extra words, allow it
            }
        }

        // Strategy 3: Fallback to pure traversal
        auto directions = direction(input_dims, 3);

        std::vector<int> response_dims;
        for (auto& [dir_id, score] : directions) {
            if (dimensions.find(dir_id) == dimensions.end()) continue;
            if (dimensions[dir_id].type == "word" && score > 0.15) {
                bool is_input_word = false;
                for (int in_id : input_dims) {
                    if (dir_id == in_id) { is_input_word = true; break; }
                }
                if (!is_input_word) {
                    response_dims.push_back(dir_id);
                    if (response_dims.size() >= 8) break;
                }
            }
        }

        if (!response_dims.empty()) {
            return reconstruct_from_dims(response_dims);
        }

        return "I don't understand that yet.";
    }

    // ----------------------------------------------------------
    // DIMENSIONAL JUMP
    // ----------------------------------------------------------
    // When a chain breaks or is too far from the target idea,
    // the system can jump to a distant dimension that shares
    // enough structure (overlap) to be valid. If the jump
    // works, a new shortcut connection is created permanently.
    // This is how the system generates novel sentences from
    // fragments of different learned conversations.
    // ----------------------------------------------------------

    // Find jumpable dimensions: words not in the current chain
    // but reachable through shared sub-dimensions (letters, tokens)
    // or through indirect connections (2+ hops away)
    struct JumpCandidate {
        int dim_id;
        double overlap_score;
        int source_id;       // where we jumped from
        std::string reason;  // why this jump is valid
    };

    std::vector<JumpCandidate> find_jumps(
        int from_id,
        const std::unordered_set<int>& excluded,
        int max_candidates = 5)
    {
        std::vector<JumpCandidate> candidates;
        if (dimensions.find(from_id) == dimensions.end()) return candidates;

        const Dimension& from_dim = dimensions[from_id];
        if (from_dim.type != "word") return candidates;

        // Strategy 1: Find words that share sub-dimensions
        // (letters, tokens) but aren't directly connected
        // These are words that LOOK like they could follow,
        // based on structural similarity

        // Get all letter/token dims connected to from_dim
        std::unordered_set<int> from_subdims;
        for (auto& [conn_id, weight] : from_dim.connections) {
            if (dimensions.find(conn_id) == dimensions.end()) continue;
            const auto& cd = dimensions[conn_id];
            if (cd.type == "letter" || cd.type == "token") {
                from_subdims.insert(conn_id);
            }
        }

        // Strategy 2: DIRECT ROUTING — check neighbors' next_words
        // Instead of scanning every seq dim globally, look at words
        // connected to from_dim, and check THEIR next_words.
        // "If a word similar to me has a next word, I can jump there."
        for (auto& [conn_id, conn_weight] : from_dim.connections) {
            if (dimensions.find(conn_id) == dimensions.end()) continue;
            if (dimensions[conn_id].type != "word") continue;
            if (conn_id == from_id) continue;

            // This neighbor has next_words — can we jump to one?
            for (auto& [next_id, next_weight] : dimensions[conn_id].next_words) {
                if (excluded.count(next_id)) continue;
                if (next_id == from_id) continue;

                // Score based on: how similar is the neighbor to us,
                // and how strong is the neighbor->next link
                double sim = conn_weight * 0.3;
                double context_score = dimensions[next_id].activation * 0.05;
                double jump_score = sim + context_score + next_weight * 0.2;

                if (jump_score >= jump_threshold) {
                    JumpCandidate jc;
                    jc.dim_id = next_id;
                    jc.overlap_score = jump_score;
                    jc.source_id = from_id;
                    jc.reason = "route_jump via " + dimensions[conn_id].content;
                    candidates.push_back(jc);
                }
            }
        }

        // Strategy 3: DIRECT ROUTING — 2-hop semantic neighborhood
        // Instead of scanning all word dims, check from_dim's word-type
        // connections' word-type connections. This is the local neighborhood.
        std::unordered_set<int> checked_semantic;
        for (auto& [conn_id, w1] : from_dim.connections) {
            if (dimensions.find(conn_id) == dimensions.end()) continue;
            if (dimensions[conn_id].type != "word" &&
                dimensions[conn_id].type != "meta") continue;

            // 2nd hop: check connections of connections
            for (auto& [hop2_id, w2] : dimensions[conn_id].connections) {
                if (dimensions.find(hop2_id) == dimensions.end()) continue;
                if (dimensions[hop2_id].type != "word") continue;
                if (excluded.count(hop2_id)) continue;
                if (hop2_id == from_id) continue;
                if (checked_semantic.count(hop2_id)) continue;
                checked_semantic.insert(hop2_id);

                // Score: product of hop weights + activation + personality
                double score = w1 * 0.15 + w2 * 0.15;
                score += dimensions[hop2_id].activation * 0.03;
                score += dimensions[hop2_id].personality * 0.1;

                if (score >= jump_threshold) {
                    bool already = false;
                    for (auto& c : candidates) {
                        if (c.dim_id == hop2_id) { already = true; break; }
                    }
                    if (!already) {
                        JumpCandidate jc;
                        jc.dim_id = hop2_id;
                        jc.overlap_score = score;
                        jc.source_id = from_id;
                        jc.reason = "semantic_2hop";
                        candidates.push_back(jc);
                    }
                }
            }
        }

        // Sort by score, take top candidates
        std::sort(candidates.begin(), candidates.end(),
            [](const JumpCandidate& a, const JumpCandidate& b) {
                return a.overlap_score > b.overlap_score;
            });

        if (candidates.size() > static_cast<size_t>(max_candidates)) {
            candidates.resize(max_candidates);
        }

        return candidates;
    }

    // Execute a jump: create a new shortcut connection
    // and a new sequence dimension so future responses
    // can use this path without jumping again
    // --- Jump validation state ---
    struct PendingJump {
        int from_id;
        int to_id;
        double score;
        int conn_created;      // was connection new?
        int seq_created;       // was seq dim new?
        int seq_id;            // seq dim id if created
        double loss_before;    // loss measurement before jump
    };

    std::vector<PendingJump> pending_jumps;
    int good_jumps;
    int bad_jumps;

    // Measure loss: how coherent is the current output relative
    // to context? Lower = better. This is what decides if a jump helped.
    double measure_loss(const std::vector<int>& output_ids,
                       const std::vector<int>& context_dims) {
        if (output_ids.empty()) return 1.0;

        double loss = 0.0;

        // 1. Context relevance: do output words relate to context?
        double context_score = overlap(output_ids, context_dims);
        loss += (1.0 - context_score) * 0.4;

        // 2. Sequence coherence: do consecutive output words have
        //    sequence dimensions connecting them?
        int seq_breaks = 0;
        int seq_total = 0;
        for (size_t i = 0; i + 1 < output_ids.size(); i++) {
            if (dimensions.find(output_ids[i]) == dimensions.end()) continue;
            if (dimensions.find(output_ids[i+1]) == dimensions.end()) continue;
            seq_total++;

            std::string seq_key = dimensions[output_ids[i]].content +
                                  "->" + dimensions[output_ids[i+1]].content;
            if (!exists(seq_key, "seq")) {
                seq_breaks++;
            }
        }
        if (seq_total > 0) {
            loss += (static_cast<double>(seq_breaks) / seq_total) * 0.3;
        }

        // 3. Internal coherence: do the output words connect to each other?
        int connected_pairs = 0;
        int total_pairs = 0;
        for (size_t i = 0; i < output_ids.size(); i++) {
            for (size_t j = i + 1; j < output_ids.size(); j++) {
                total_pairs++;
                if (dimensions[output_ids[i]].connections.count(output_ids[j])) {
                    connected_pairs++;
                }
            }
        }
        if (total_pairs > 0) {
            loss += (1.0 - static_cast<double>(connected_pairs) / total_pairs) * 0.3;
        }

        return std::max(0.0, std::min(1.0, loss));
    }

    // Try a jump tentatively — create connection but track it for rollback
    PendingJump try_jump(int from_id, int to_id, double score,
                         const std::vector<int>& current_output,
                         const std::vector<int>& context_dims) {
        PendingJump pj;
        pj.from_id = from_id;
        pj.to_id = to_id;
        pj.score = score;
        pj.seq_id = -1;

        // Measure loss BEFORE the jump
        pj.loss_before = measure_loss(current_output, context_dims);

        // Check if connection already exists
        pj.conn_created = (dimensions[from_id].connections.find(to_id) ==
                          dimensions[from_id].connections.end()) ? 1 : 0;

        // Create tentative connection
        connect(from_id, to_id, score * 0.8);

        // Wire direct routing
        dimensions[from_id].next_words[to_id] += score * 0.5;
        dimensions[to_id].prev_words[from_id] += score * 0.5;

        // Create tentative sequence dim
        std::string from_word = dimensions[from_id].content;
        std::string to_word = dimensions[to_id].content;
        std::string jump_seq = from_word + "->" + to_word;

        if (!exists(jump_seq, "seq")) {
            pj.seq_id = get_or_create(jump_seq, "seq");
            connect(pj.seq_id, from_id, 1.0);
            connect(pj.seq_id, to_id, 1.0);
            pj.seq_created = 1;
        } else {
            pj.seq_created = 0;
        }

        return pj;
    }

    // Validate jump: did loss go down?
    bool validate_jump(const PendingJump& pj,
                      const std::vector<int>& new_output,
                      const std::vector<int>& context_dims) {
        double loss_after = measure_loss(new_output, context_dims);
        return loss_after < pj.loss_before;
    }

    // Commit a good jump — keep the connection, reinforce gates
    void commit_jump(const PendingJump& pj) {
        jump_count++;
        good_jumps++;

        // Reinforce gates: this jump was useful
        gate_reinforce(pj.from_id, "output", 0.5);
        gate_reinforce(pj.to_id, "input", 0.5);
        gate_reinforce(pj.to_id, "output", 0.3);
    }

    // Simple execute_jump for direct use
    void execute_jump(int from_id, int to_id, double score) {
        connect(from_id, to_id, score * 0.8);
        std::string from_word = dimensions[from_id].content;
        std::string to_word = dimensions[to_id].content;
        std::string jump_seq = from_word + "->" + to_word;
        if (!exists(jump_seq, "seq")) {
            int seq_id = get_or_create(jump_seq, "seq");
            connect(seq_id, from_id, 1.0);
            connect(seq_id, to_id, 1.0);
        }
        jump_count++;
    }

    // Rollback a bad jump — remove the connection, penalize gates
    void rollback_jump(const PendingJump& pj) {
        bad_jumps++;

        // Remove the tentative connection
        if (pj.conn_created) {
            dimensions[pj.from_id].connections.erase(pj.to_id);
            dimensions[pj.to_id].connections.erase(pj.from_id);
        }

        // Remove direct routing
        dimensions[pj.from_id].next_words.erase(pj.to_id);
        dimensions[pj.to_id].prev_words.erase(pj.from_id);

        // Remove the tentative seq dim
        if (pj.seq_created && pj.seq_id >= 0) {
            // Disconnect seq dim
            for (auto& [conn_id, w] : dimensions[pj.seq_id].connections) {
                dimensions[conn_id].connections.erase(pj.seq_id);
            }
            dimensions[pj.seq_id].connections.clear();
            // Mark as inactive (don't delete, just disconnect)
            dimensions[pj.seq_id].activation = 0;
        }

        // Penalize gates: this path was bad
        gate_reinforce(pj.from_id, "output", -0.3);
        gate_reinforce(pj.to_id, "input", -0.3);
    }

    // Generate a response using jumps when chains break
    // This is the key method for novel sentence generation
    std::string generate_with_jumps(
        const std::vector<int>& seed_dims,
        const std::vector<int>& context_dims,
        int max_words = 10)
    {
        std::vector<int> output_word_ids;
        std::unordered_set<int> used;

        // Find starting word using DIRECT ROUTING
        // Check start_weight on seed words — no global scan
        int current = -1;
        double best_start = -1.0;

        for (int id : seed_dims) {
            if (dimensions.find(id) == dimensions.end()) continue;
            if (dimensions[id].type != "word") continue;
            double sw = dimensions[id].start_weight + dimensions[id].activation * 0.1;
            if (sw > best_start) {
                best_start = sw;
                current = id;
            }
        }

        // Also check words reachable from seed dims that are starters
        if (current < 0 || best_start <= 0) {
            for (int id : seed_dims) {
                if (dimensions.find(id) == dimensions.end()) continue;
                for (auto& [conn_id, w] : dimensions[id].connections) {
                    if (dimensions[conn_id].type == "word" &&
                        dimensions[conn_id].start_weight > best_start) {
                        best_start = dimensions[conn_id].start_weight;
                        current = conn_id;
                    }
                }
            }
        }

        // Final fallback: highest activation word in seed dims
        if (current < 0) {
            for (int id : seed_dims) {
                if (dimensions[id].type == "word" &&
                    dimensions[id].activation > best_start) {
                    best_start = dimensions[id].activation;
                    current = id;
                }
            }
        }

        if (current < 0) return "";

        // Walk + jump loop using DIRECT ROUTING
        while (current >= 0 &&
               output_word_ids.size() < static_cast<size_t>(max_words) &&
               !used.count(current))
        {
            output_word_ids.push_back(current);
            used.insert(current);

            // DIRECT LOOKUP: check this word's next_words map
            // No scanning. The wiring IS the routing.
            int next = -1;
            double best_w = -1.0;

            for (auto& [next_id, weight] : dimensions[current].next_words) {
                if (used.count(next_id)) continue;
                if (dimensions.find(next_id) == dimensions.end()) continue;

                // Signal: what's uniquely active right now
                double sig = std::max(0.1, dimensions[next_id].signal());
                double w = weight * sig +
                           dimensions[next_id].personality * 0.3 +
                           dimensions[next_id].output_gate * 0.2;
                if (w > best_w) {
                    best_w = w;
                    next = next_id;
                }
            }

            // If chain breaks, try jumping
            if (next < 0) {
                auto jumps = find_jumps(current, used, 3);
                if (!jumps.empty()) {
                    JumpCandidate& best = jumps[0];

                    // Context check: does destination relate to conversation?
                    bool worth_trying = false;
                    for (int ctx_id : context_dims) {
                        if (dimensions[best.dim_id].connections.count(ctx_id)) {
                            worth_trying = true;
                            break;
                        }
                    }
                    if (!worth_trying && best.overlap_score > jump_threshold * 2) {
                        worth_trying = true;
                    }

                    if (worth_trying) {
                        // TRY the jump tentatively
                        PendingJump pj = try_jump(current, best.dim_id,
                                                  best.overlap_score,
                                                  output_word_ids, context_dims);

                        // Build what output would look like WITH this jump
                        std::vector<int> test_output = output_word_ids;
                        test_output.push_back(best.dim_id);

                        // VALIDATE: did loss go down?
                        if (validate_jump(pj, test_output, context_dims)) {
                            commit_jump(pj);
                            next = best.dim_id;
                        } else {
                            rollback_jump(pj);
                            // Try next best jump candidate
                            for (size_t ji = 1; ji < jumps.size() && next < 0; ji++) {
                                PendingJump pj2 = try_jump(current, jumps[ji].dim_id,
                                                           jumps[ji].overlap_score,
                                                           output_word_ids, context_dims);
                                std::vector<int> test2 = output_word_ids;
                                test2.push_back(jumps[ji].dim_id);
                                if (validate_jump(pj2, test2, context_dims)) {
                                    commit_jump(pj2);
                                    next = jumps[ji].dim_id;
                                } else {
                                    rollback_jump(pj2);
                                }
                            }
                        }
                    }
                }
            }

            current = next;
        }

        // Build output string
        std::string result;
        for (int id : output_word_ids) {
            if (!result.empty()) result += " ";
            result += dimensions[id].content;
        }
        return result;
    }

    // ----------------------------------------------------------
    // CAUSAL CONFOUNDER REJECTION
    // ----------------------------------------------------------
    // If A and B are correlated, check whether a third dimension C
    // explains the correlation. If removing C breaks the A-B link,
    // the correlation was confounded.
    // ----------------------------------------------------------

    bool is_confounded(int dim_a, int dim_b, double threshold = 0.3) {
        if (dimensions.find(dim_a) == dimensions.end()) return false;
        if (dimensions.find(dim_b) == dimensions.end()) return false;

        auto& conn_a = dimensions[dim_a].connections;
        auto& conn_b = dimensions[dim_b].connections;

        // Find shared connections (potential confounders)
        for (auto& [c_id, a_weight] : conn_a) {
            if (c_id == dim_b) continue;
            auto it = conn_b.find(c_id);
            if (it == conn_b.end()) continue;

            double c_weight = it->second;

            // If C connects to both A and B more strongly than A-B connect
            // to each other, C is likely a confounder
            auto ab_it = conn_a.find(dim_b);
            double ab_weight = (ab_it != conn_a.end()) ? ab_it->second : 0.0;

            if (a_weight > ab_weight && c_weight > ab_weight) {
                // C explains the A-B correlation better than direct link
                if ((a_weight + c_weight) / 2.0 - ab_weight > threshold) {
                    return true;
                }
            }
        }
        return false;
    }

    // ----------------------------------------------------------
    // STATS
    // ----------------------------------------------------------

    // Thought record - what the system discovered on its own
    struct Thought {
        int start_id;            // where the thought began
        int discovery_id;        // where it ended up
        std::vector<int> path;   // dimensions traversed
        double surprise;         // how unexpected this connection was
        std::string description; // human-readable summary
        bool novel_connection;   // did this create a new link?
    };

    std::vector<Thought> thought_log;
    int thought_cycles;          // total think cycles run

    // ----------------------------------------------------------
    // THOUGHT SYSTEM
    // ----------------------------------------------------------
    // The field runs FORWARD on its own with no input.
    // Activation propagates, follows direction, lands somewhere.
    // When it finds an unexpected connection (low overlap between
    // start and destination but strong intermediate path), that's
    // a discovery. The system just "realized" something.
    // ----------------------------------------------------------

    // Measure surprise: how unexpected is the connection between
    // two dimensions? High surprise = low direct overlap but
    // reachable through strong intermediate connections
    double measure_surprise(int from_id, int to_id) {
        if (dimensions.find(from_id) == dimensions.end()) return 0.0;
        if (dimensions.find(to_id) == dimensions.end()) return 0.0;

        // Direct connection strength (if any)
        double direct = 0.0;
        auto& conns = dimensions[from_id].connections;
        auto it = conns.find(to_id);
        if (it != conns.end()) {
            direct = it->second;
        }

        // Shared sub-dimensions (letters, tokens)
        int shared_sub = 0;
        int total_sub = 0;
        for (auto& [c1, w1] : dimensions[from_id].connections) {
            if (dimensions[c1].type == "letter" || dimensions[c1].type == "token") {
                total_sub++;
                if (dimensions[to_id].connections.count(c1)) {
                    shared_sub++;
                }
            }
        }
        double structural_sim = (total_sub > 0)
            ? static_cast<double>(shared_sub) / total_sub : 0.0;

        // Shared word-level connections (semantic similarity)
        int shared_semantic = 0;
        int total_semantic = 0;
        for (auto& [c1, w1] : dimensions[from_id].connections) {
            if (dimensions[c1].type == "word" || dimensions[c1].type == "meta") {
                total_semantic++;
                if (dimensions[to_id].connections.count(c1)) {
                    shared_semantic++;
                }
            }
        }
        double semantic_sim = (total_semantic > 0)
            ? static_cast<double>(shared_semantic) / total_semantic : 0.0;

        // Surprise is HIGH when:
        // - Low direct connection (they aren't already linked)
        // - Low structural similarity (they don't look alike)
        // - BUT some semantic connection exists (they share a neighborhood)
        // The sweet spot: not totally random, but not obvious either

        double obviousness = direct * 0.5 + structural_sim * 0.3 + semantic_sim * 0.2;

        // Surprise = how non-obvious the connection is,
        // scaled by whether there IS a discoverable link
        if (semantic_sim < 0.01 && direct < 0.01) {
            return 0.0; // totally unrelated, not surprising, just random
        }

        double surprise = (1.0 - obviousness) * (semantic_sim + 0.1);
        return std::max(0.0, surprise);
    }

    // ----------------------------------------------------------
    // SELF-QUERY: Ask the field what it knows about a word
    // ----------------------------------------------------------
    // Instead of hardcoding which words are "grammar" vs "concept",
    // the system checks its OWN learned knowledge. If the field
    // has learned that "is connects things" and "the points to
    // a specific thing", it can use that knowledge to recognize
    // connector words and skip them during thinking.
    // ----------------------------------------------------------

    // How conceptual is this word? Returns 0.0-1.0
    // Low = the field thinks this word is a connector/grammar word
    // High = the field thinks this word is a real concept
    //
    // Uses the field's OWN overlap primitive to ask:
    // "How much does this word overlap with what the field knows
    //  about grammar and connector words?"
    double how_conceptual(int word_id) {
        // Check cache first
        auto cache_it = conceptual_cache.find(word_id);
        if (cache_it != conceptual_cache.end()) return cache_it->second;

        if (dimensions.find(word_id) == dimensions.end()) return 0.5;
        const Dimension& word = dimensions[word_id];
        if (word.type != "word") return 0.5;

        // Build grammar reference dims (cached after first call)
        // These represent what the field has learned about connector words
        if (grammar_ref_dims.empty()) {
            // Collect dims from grammar-related concepts the system knows
            std::vector<std::string> grammar_probes = {
                "connects", "links", "joins", "points",
                "grammar", "sentence", "structure",
                "subject", "description", "direction",
                "condition", "purpose", "refers",
                "introduces", "reverses", "permission"
            };
            for (auto& probe : grammar_probes) {
                std::string key = "word:" + probe;
                auto it = lookup.find(key);
                if (it != lookup.end()) {
                    grammar_ref_dims.push_back(it->second);
                }
            }
        }

        if (grammar_ref_dims.empty()) return 0.5; // no grammar knowledge yet

        // Use the field's overlap primitive:
        // How much does this word overlap with grammar concepts?
        std::vector<int> word_dims = {word_id};

        // Also include this word's direct word-neighbors for richer comparison
        for (auto& [conn_id, w] : word.connections) {
            if (dimensions.find(conn_id) != dimensions.end() &&
                dimensions.at(conn_id).type == "word" && w > 0.5) {
                word_dims.push_back(conn_id);
                if (word_dims.size() > 20) break; // cap for speed
            }
        }

        double grammar_overlap = overlap(word_dims, grammar_ref_dims);

        // Also factor in connection density
        // Words that appear everywhere are likely grammar
        int word_neighbors = 0;
        for (auto& [c, w] : word.connections) {
            if (dimensions.find(c) != dimensions.end() &&
                dimensions.at(c).type == "word") word_neighbors++;
        }
        double density_penalty = 1.0 / (1.0 + word_neighbors * 0.01);

        // Conceptual = NOT grammar AND NOT a hub
        double conceptual = (1.0 - grammar_overlap * 3.0) * (0.4 + density_penalty * 0.6);
        double result = std::max(0.0, std::min(1.0, conceptual));
        conceptual_cache[word_id] = result;
        return result;
    }

    // Cache for grammar reference dimensions (rebuilt when empty)
    mutable std::vector<int> grammar_ref_dims;
    mutable std::unordered_map<int, double> conceptual_cache;

    // Run one thought cycle: pick a starting point, traverse,
    // look for surprises, log discoveries
    Thought think_once() {
        Thought thought;
        thought.surprise = 0.0;
        thought.novel_connection = false;
        thought.start_id = -1;
        thought.discovery_id = -1;
        thought_cycles++;

        // Pick starting dimension: weighted by activation
        // (think about what's on your "mind")
        // Only start from concept words, not grammar glue
        std::vector<std::pair<int, double>> candidates;
        for (auto& [id, d] : dimensions) {
            if (d.type == "word" && d.activation > 0.1) {
                double concept_val = how_conceptual(id);
                double tg = d.think_gate;
                if (concept_val * tg > 0.2) { // both knowledge and learned gate
                    candidates.push_back({id, d.activation * concept_val * tg});
                }
            }
        }

        if (candidates.empty()) return thought;

        // Weighted random selection based on activation
        double total_act = 0;
        for (auto& [id, act] : candidates) total_act += act;

        // Use thought_cycles as seed for deterministic but varied selection
        std::mt19937 rng(thought_cycles * 7919 + 42);
        std::uniform_real_distribution<double> dist(0.0, total_act);
        double pick = dist(rng);

        double cumulative = 0;
        int start_id = candidates[0].first;
        for (auto& [id, act] : candidates) {
            cumulative += act;
            if (cumulative >= pick) {
                start_id = id;
                break;
            }
        }

        thought.start_id = start_id;
        thought.path.push_back(start_id);

        // Traverse: follow direction vectors, up to 5 steps
        std::unordered_set<int> visited;
        visited.insert(start_id);
        int current = start_id;
        int best_discovery = -1;
        double best_surprise = 0.0;

        for (int step = 0; step < 5; step++) {
            // Get direction from current position
            auto dirs = direction({current}, 1);

            // Filter to word-type dims not yet visited
            int next = -1;
            double next_score = -1.0;

            for (auto& [dir_id, score] : dirs) {
                if (visited.count(dir_id)) continue;
                if (dimensions[dir_id].type != "word") continue;

                // ASK THE FIELD: is this word a concept or a connector?
                // Skip connector words - they're not interesting discoveries
                double concept_score = how_conceptual(dir_id);
                double tgate = dimensions[dir_id].think_gate;
                double thinkability = concept_score * tgate;
                if (thinkability < 0.2) continue; // field + experience say skip

                // Prefer directions that are surprising relative to start
                double surprise = measure_surprise(start_id, dir_id);
                double combined = score * 0.2 + surprise * 0.4 + thinkability * 0.4;

                if (combined > next_score) {
                    next_score = combined;
                    next = dir_id;
                }
            }

            if (next < 0) break; // dead end

            visited.insert(next);
            thought.path.push_back(next);

            // Measure surprise from start to here
            double surprise = measure_surprise(start_id, next);
            if (surprise > best_surprise) {
                best_surprise = surprise;
                best_discovery = next;
            }

            current = next;
        }

        // Did we find something surprising?
        if (best_discovery >= 0 && best_surprise > 0.1) {
            thought.discovery_id = best_discovery;
            thought.surprise = best_surprise;

            // Build description
            std::string start_word = dimensions[start_id].content;
            std::string disc_word = dimensions[best_discovery].content;
            thought.description = start_word + " -> " + disc_word;

            // --- GATE LEARNING FROM DISCOVERY ---
            // Good discovery: reinforce think_gates along the path
            // The path dimensions proved useful for thinking
            gate_reinforce_path(thought.path, "think", best_surprise);

            // The discovery endpoint is interesting: boost its output_gate
            // (it has something worth saying) and think_gate
            gate_reinforce(best_discovery, "think", best_surprise * 0.5);
            gate_reinforce(best_discovery, "output", best_surprise * 0.3);

            // Create new connection if one doesn't exist
            auto& start_conns = dimensions[start_id].connections;
            if (start_conns.find(best_discovery) == start_conns.end()) {
                connect(start_id, best_discovery, best_surprise * 0.5);
                thought.novel_connection = true;

                std::string thought_seq = start_word + "->" + disc_word;
                if (!exists(thought_seq, "seq")) {
                    int seq_id = get_or_create(thought_seq, "seq");
                    connect(seq_id, start_id, 0.5);
                    connect(seq_id, best_discovery, 0.5);
                }
            } else {
                start_conns[best_discovery] += best_surprise * 0.1;
            }

            // Deposit along the path to reinforce it
            for (int path_id : thought.path) {
                deposit(path_id, best_surprise * 0.3);
            }
        } else {
            // --- GATE LEARNING FROM FAILURE ---
            // Boring thought or dead end: reduce think_gates along path
            // These dimensions didn't lead anywhere interesting
            for (int path_id : thought.path) {
                gate_reinforce(path_id, "think", -0.3);
            }
        }

        thought_log.push_back(thought);
        return thought;
    }

    // Run multiple thought cycles
    std::vector<Thought> think(int cycles = 10) {
        std::vector<Thought> discoveries;
        for (int i = 0; i < cycles; i++) {
            Thought t = think_once();
            if (t.surprise > 0.1) {
                discoveries.push_back(t);
            }
            // Periodic activation decay so the field doesn't saturate
            if (i % 10 == 0) {
                decay_activations();
            }
        }
        return discoveries;
    }

    // Get the most surprising thoughts so far
    std::vector<Thought> top_thoughts(int n = 5) const {
        std::vector<Thought> sorted = thought_log;
        std::sort(sorted.begin(), sorted.end(),
            [](const Thought& a, const Thought& b) {
                return a.surprise > b.surprise;
            });
        if (sorted.size() > static_cast<size_t>(n)) {
            sorted.resize(n);
        }
        return sorted;
    }

    // Check if the system discovered a specific connection
    // through thinking (not through direct training)
    bool discovered(const std::string& word_a, const std::string& word_b) const {
        for (auto& t : thought_log) {
            if (t.discovery_id < 0 || t.start_id < 0) continue;
            if (!t.novel_connection) continue;
            const auto& s = dimensions.at(t.start_id);
            const auto& d = dimensions.at(t.discovery_id);
            if ((s.content == word_a && d.content == word_b) ||
                (s.content == word_b && d.content == word_a)) {
                return true;
            }
        }
        return false;
    }

    // Print thought log
    void print_thoughts(int max_show = 10) const {
        std::cout << "=== Thought Log ===" << std::endl;
        std::cout << "Total cycles: " << thought_cycles << std::endl;
        std::cout << "Discoveries: " << thought_log.size() << std::endl;
        int novel = 0;
        for (auto& t : thought_log) {
            if (t.novel_connection) novel++;
        }
        std::cout << "Novel connections created: " << novel << std::endl;

        auto top = top_thoughts(max_show);
        if (!top.empty()) {
            std::cout << "Top discoveries:" << std::endl;
            for (auto& t : top) {
                std::cout << "  " << t.description
                          << " (surprise: " << t.surprise
                          << (t.novel_connection ? " NEW" : " reinforced")
                          << " path:";
                for (int id : t.path) {
                    std::cout << " " << dimensions.at(id).content;
                }
                std::cout << ")" << std::endl;
            }
        }
        std::cout << "===================" << std::endl;
    }

    int total_dimensions() const { return static_cast<int>(dimensions.size()); }

    int total_connections() const {
        int count = 0;
        for (auto& [id, d] : dimensions) {
            count += static_cast<int>(d.connections.size());
        }
        return count / 2; // bidirectional
    }

    void print_stats() const {
        std::cout << "=== Field Stats ===" << std::endl;
        std::cout << "Dimensions: " << total_dimensions() << std::endl;
        std::cout << "Connections: " << total_connections() << std::endl;
        std::cout << "Conversation memories: "
                  << conversation_memory.size() << std::endl;
        std::cout << "Personality traits: "
                  << personality_dims.size() << std::endl;
        std::cout << "Dimensional jumps: "
                  << jump_count << " (good: " << good_jumps
                  << " bad: " << bad_jumps << ")" << std::endl;

        // Count by type
        std::map<std::string, int> type_counts;
        for (auto& [id, d] : dimensions) {
            type_counts[d.type]++;
        }
        std::cout << "Dimensions by type:" << std::endl;
        for (auto& [type, count] : type_counts) {
            std::cout << "  " << type << ": " << count << std::endl;
        }

        // Gate statistics for word dimensions
        double avg_input = 0, avg_output = 0, avg_think = 0, avg_forget = 0;
        int word_count = 0;
        double min_think = 1.0, max_think = 0.0;
        std::string min_think_word, max_think_word;

        for (auto& [id, d] : dimensions) {
            if (d.type != "word") continue;
            word_count++;
            avg_input += d.input_gate;
            avg_output += d.output_gate;
            avg_think += d.think_gate;
            avg_forget += d.forget_gate;
            if (d.think_gate < min_think) {
                min_think = d.think_gate; min_think_word = d.content;
            }
            if (d.think_gate > max_think) {
                max_think = d.think_gate; max_think_word = d.content;
            }
        }
        if (word_count > 0) {
            std::cout << "Gate averages (words):" << std::endl;
            std::cout << "  input: " << avg_input/word_count
                      << "  output: " << avg_output/word_count
                      << "  think: " << avg_think/word_count
                      << "  forget: " << avg_forget/word_count << std::endl;
            std::cout << "  lowest think: \"" << min_think_word
                      << "\" (" << min_think << ")" << std::endl;
            std::cout << "  highest think: \"" << max_think_word
                      << "\" (" << max_think << ")" << std::endl;
        }
        std::cout << "===================" << std::endl;
    }

    // Dump specific dimension info
    void print_dimension(int id) const {
        if (dimensions.find(id) == dimensions.end()) {
            std::cout << "Dimension " << id << " not found." << std::endl;
            return;
        }
        const Dimension& d = dimensions.at(id);
        std::cout << "Dim[" << d.id << "] \"" << d.content
                  << "\" type=" << d.type
                  << " act=" << d.activation
                  << " gates=[i:" << d.input_gate
                  << " o:" << d.output_gate
                  << " t:" << d.think_gate
                  << " f:" << d.forget_gate << "]"
                  << " conns=" << d.connections.size()
                  << std::endl;
    }

private:
    // Gaussian function
    double gaussian(double distance, double sigma) const {
        return std::exp(-(distance * distance) / (2.0 * sigma * sigma));
    }

    // Split string into words
    std::vector<std::string> split_words(const std::string& text) const {
        std::vector<std::string> words;
        std::string word;
        for (char c : text) {
            if (c == ' ' || c == '\t' || c == '\n' || c == ',' ||
                c == '.' || c == '!' || c == '?' || c == ';' || c == ':') {
                if (!word.empty()) {
                    words.push_back(word);
                    word.clear();
                }
            } else {
                word += c;
            }
        }
        if (!word.empty()) words.push_back(word);
        return words;
    }

    // Lowercase
    std::string to_lower(const std::string& s) const {
        std::string result = s;
        for (char& c : result) {
            if (c >= 'A' && c <= 'Z') c += 32;
        }
        return result;
    }

    // Reconstruct text from a set of dimension IDs
    // Uses sequence dimensions to preserve word order.
    // Falls back to activation sort if no sequence info exists.
    std::string reconstruct_from_dims(const std::vector<int>& dims) const {
        // Collect word-level dims
        std::unordered_set<int> word_ids;
        std::unordered_map<int, std::string> id_to_word;

        for (int id : dims) {
            if (dimensions.find(id) == dimensions.end()) continue;
            const Dimension& d = dimensions.at(id);
            if (d.type == "word") {
                word_ids.insert(id);
                id_to_word[id] = d.content;
            }
        }

        if (word_ids.empty()) return "";

        // --- DIRECT ROUTING: no global scan needed ---

        // Build chain from direct routing, filtered to this response's words
        // Score uses SIGNAL — what's uniquely active right now, not what's
        // always active. "is" always active = low signal = low score.
        // "dolphins" rarely active but hot right now = high signal = high score.
        std::unordered_map<int, std::vector<std::pair<int, double>>> chain;
        for (int wid : word_ids) {
            const Dimension& wd = dimensions.at(wid);
            for (auto& [next_id, weight] : wd.next_words) {
                if (word_ids.count(next_id)) {
                    // Signal of the destination: how unique is it right now?
                    double sig = std::max(0.1, dimensions.at(next_id).signal());
                    // Chain score = routing weight × signal
                    double score = weight * sig + 5.0; // base bonus for being in-set
                    chain[wid].push_back({next_id, score});
                }
            }
        }

        // --- Find start word ---
        // Source node (has outgoing, no incoming in this set)
        // Start selection stays structural — signal is for the walk
        int start_word = -1;
        {
            std::unordered_set<int> has_incoming;
            for (auto& [from, tos] : chain) {
                for (auto& [to, w] : tos) {
                    has_incoming.insert(to);
                }
            }

            // Among source nodes, prefer the one with highest start_weight
            double best_source = -1.0;
            for (auto& [from, tos] : chain) {
                if (!has_incoming.count(from)) {
                    double score = dimensions.at(from).start_weight + 1.0;
                    if (score > best_source) {
                        best_source = score;
                        start_word = from;
                    }
                }
            }

            // No source nodes? Everything has incoming — cycle.
            // Pick word with highest start_weight in the set
            if (start_word < 0) {
                for (int wid : word_ids) {
                    double sw = dimensions.at(wid).start_weight;
                    if (sw > best_source) {
                        best_source = sw;
                        start_word = wid;
                    }
                }
            }
        }

        // Final fallback
        if (start_word < 0 && !word_ids.empty()) {
            start_word = *word_ids.begin();
        }

        // Walk the chain
        std::string result;
        std::unordered_set<int> used;
        int current = start_word;

        while (current >= 0 && !used.count(current)) {
            used.insert(current);
            if (!result.empty()) result += " ";
            result += id_to_word[current];

            // Direct lookup: what follows this word?
            int next = -1;
            double best_w = -1.0;
            auto it = chain.find(current);
            if (it != chain.end()) {
                for (auto& [to_id, w] : it->second) {
                    if (!used.count(to_id) && w > best_w) {
                        best_w = w;
                        next = to_id;
                    }
                }
            }
            current = next;
        }

        // Append unchained words
        for (int wid : word_ids) {
            if (!used.count(wid)) {
                if (!result.empty()) result += " ";
                result += id_to_word[wid];
            }
        }

        if (!result.empty()) return result;

        // Fallback
        std::string fallback;
        for (int wid : word_ids) {
            if (!fallback.empty()) fallback += " ";
            fallback += id_to_word[wid];
        }
        return fallback;
    }
};


