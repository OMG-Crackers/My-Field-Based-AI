struct TestResult {
    std::string name;
    bool passed;
    std::string detail;
};

class TestRunner {
public:
    std::vector<TestResult> results;

    void run(const std::string& name, std::function<bool(std::string&)> test) {
        std::string detail;
        bool passed = false;
        try {
            passed = test(detail);
        } catch (const std::exception& e) {
            detail = std::string("EXCEPTION: ") + e.what();
            passed = false;
        }
        results.push_back({name, passed, detail});
        std::cout << (passed ? "[PASS] " : "[FAIL] ") << name;
        if (!detail.empty()) std::cout << " -- " << detail;
        std::cout << std::endl;
    }

    void summary() {
        int passed = 0, failed = 0;
        for (auto& r : results) {
            if (r.passed) passed++; else failed++;
        }
        std::cout << "\n=== RESULTS: " << passed << "/" << (passed + failed)
                  << " passed ===" << std::endl;
        if (failed > 0) {
            std::cout << "FAILURES:" << std::endl;
            for (auto& r : results) {
                if (!r.passed) {
                    std::cout << "  - " << r.name << ": " << r.detail << std::endl;
                }
            }
        }
    }
};


