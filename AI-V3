void benchmark_text_classification(SmartAI& ai, std::mt19937& rng) {
    printf("\n=== Text Classification Benchmark ===\n");
    std::vector<std::pair<std::string, std::string>> dataset = {
        {"sports", "team scored goal"}, {"sports", "player kicked ball"}, {"sports", "coach led victory"},
        {"sports", "crowd cheered goal"}, {"sports", "athlete broke record"}, {"sports", "game was exciting"},
        {"sports", "scoreboard lit up"}, {"sports", "referee blew whistle"},
        {"science", "researcher discovered species"}, {"science", "experiment confirmed hypothesis"},
        {"science", "telescope observed galaxy"}, {"science", "vaccine showed promise"},
        {"science", "cell divided under microscope"}, {"science", "lab equipment was calibrated"},
        {"science", "data analysis proved theory"}, {"science", "particle collider detected anomaly"},
        {"politics", "senator voted legislation"}, {"politics", "president signed order"},
        {"politics", "governor declared emergency"}, {"politics", "campaign speech rallied voters"},
        {"politics", "debate focused on economy"}, {"politics", "committee approved bill"},
        {"technology", "software deployed update"}, {"technology", "algorithm processed data"},
        {"technology", "startup launched app"}, {"technology", "hardware accelerated computation"},
        {"technology", "network secured against attack"}, {"technology", "cloud storage expanded"},
        {"music", "guitarist played solo"}, {"music", "orchestra performed symphony"},
        {"music", "singer released album"}, {"music", "drummer kept rhythm steady"},
        {"music", "pianist played concerto"}, {"music", "crowd sang along"}
    };
    int train_size = (int)(dataset.size() * 0.8);
    std::shuffle(dataset.begin(), dataset.end(), rng);
    std::vector<std::pair<std::string, std::vector<std::string>>> train_data, test_data;
    for (size_t i = 0; i < dataset.size(); ++i) {
        auto tokens = split(dataset[i].second);
        if (i < train_size) train_data.push_back({dataset[i].first, tokens});
        else test_data.push_back({dataset[i].first, tokens});
    }
    ai.train(train_data);
    int correct = 0;
    for (auto& [cat, toks] : test_data) {
        auto res = ai.classify(toks);
        if (res.best == cat) ++correct;
    }
    printf("Accuracy: %.2f%% (%d/%d)\n", 100.0 * correct / test_data.size(), correct, (int)test_data.size());
}

void benchmark_physics_prediction(SmartAI& ai, std::mt19937& rng) {
    printf("\n=== Physics Prediction Benchmark ===\n");
    int total_objects = 500;
    int train_count = 400;
    std::vector<PhysObj> train_objs, test_objs;
    for (int i = 0; i < total_objects; ++i) {
        auto obj = make_obj(i, rng);
        if (i < train_count) train_objs.push_back(obj);
        else test_objs.push_back(obj);
    }
    for (auto& obj : train_objs) {
        ai.perceive(obj.name, obj, rng);
        bool fragile = obj.fragility() < 0.5f;
        ai.experience("drop", obj.name, fragile);
        ai.experience("throw", obj.name, fragile);
    }
    int correct_drop = 0, correct_throw = 0;
    for (auto& obj : test_objs) {
        ai.perceive(obj.name, obj, rng);
        bool fragile = obj.fragility() < 0.5f;
        auto pred_drop = ai.predict("drop", obj.name);
        auto pred_throw = ai.predict("throw", obj.name);
        if (pred_drop.success == fragile) ++correct_drop;
        if (pred_throw.success == fragile) ++correct_throw;
    }
    printf("Drop accuracy: %.2f%% (%d/%d)\n", 100.0 * correct_drop / test_objs.size(), correct_drop, (int)test_objs.size());
    printf("Throw accuracy: %.2f%% (%d/%d)\n", 100.0 * correct_throw / test_objs.size(), correct_throw, (int)test_objs.size());
}

void benchmark_causal_chains(SmartAI& ai) {
    printf("\n=== Causal Chain Benchmark ===\n");
    std::vector<std::pair<std::string, std::string>> edges = {
        {"a","b"}, {"b","c"}, {"c","d"},
        {"x","y"}, {"y","z"},
        {"c","z"}
    };
    for (auto& [c, e] : edges) ai.observe(c, e);
    struct Test { std::string cause, effect; bool expected; int min_edges; };
    std::vector<Test> tests = {
        {"a","b", true, 1}, {"a","d", true, 3}, {"a","z", true, 3},
        {"x","z", true, 2}, {"b","x", false, 0}, {"d","a", false, 0},
    };
    int correct = 0;
    for (auto& t : tests) {
        auto res = ai.predict_causal(t.cause, t.effect);
        bool ok = (res.causes == t.expected);
        if (ok && t.expected && (int)res.chain.size() - 1 != t.min_edges) ok = false;
        if (ok) ++correct;
        else printf("  Failed: %s -> %s (expected %s, got %s, chain length %zu)\n",
                    t.cause.c_str(), t.effect.c_str(), t.expected ? "yes" : "no",
                    res.causes ? "yes" : "no", res.chain.size());
    }
    printf("Causal accuracy: %.2f%% (%d/%d)\n", 100.0 * correct / tests.size(), correct, (int)tests.size());
}

void benchmark_memory_recall(SmartAI& ai) {
    printf("\n=== Memory Recall Benchmark ===\n");
    std::vector<std::pair<std::string, std::string>> pairs = {
        {"apple","fruit"}, {"car","vehicle"}, {"dog","animal"}, {"blue","color"}, {"happy","emotion"}
    };
    for (auto& [k, v] : pairs) {
        ai.remember({k, v});
    }
    int failed = 0;
    for (auto& [k, v] : pairs) {
        auto rec = ai.recall({k}, 1);
        if (rec.empty() || rec[0].first != v) {
            ++failed;
            printf("  Recall failed for '%s' -> expected '%s', got '%s'\n",
                   k.c_str(), v.c_str(), rec.empty() ? "nothing" : rec[0].first.c_str());
        }
    }
    if (failed == 0) printf("All pairs recalled correctly.\n");
    else printf("%d failures out of %d\n", failed, (int)pairs.size());
}

void benchmark_integrated_reasoning(SmartAI& ai, std::mt19937& rng) {
    printf("\n=== Integrated Reasoning Benchmark ===\n");
    // Many examples for each material
    std::vector<std::pair<std::string, std::vector<std::string>>> text_data = {
        {"glass", split("glass is transparent")}, {"glass", split("glass can shatter")},
        {"glass", split("windows are made of glass")}, {"glass", split("glass is fragile")},
        {"rubber", split("rubber is bouncy")}, {"rubber", split("rubber is elastic")},
        {"rubber", split("tires are made of rubber")}, {"rubber", split("rubber does not break easily")},
        {"wood", split("wood is solid")}, {"wood", split("wood comes from trees")},
        {"wood", split("furniture is often wood")}, {"wood", split("wood can splinter")},
        {"metal", split("metal is hard")}, {"metal", split("metal conducts electricity")},
        {"metal", split("tools are often metal")}, {"metal", split("metal is strong")},
    };
    ai.train(text_data);
    std::unordered_map<std::string, std::string> material_to_obj;
    for (int i = 0; i < N_MATS; ++i) {
        auto obj = make_obj(i, rng);
        obj.material = MATS[i].name;
        ai.perceive(obj.name, obj, rng);
        bool fragile = obj.fragility() < 0.5f;
        ai.experience("drop", obj.name, fragile);
        material_to_obj[obj.material] = obj.name;
    }
    std::vector<std::string> queries = {"drop glass", "drop rubber", "drop wood", "drop metal"};
    for (auto& q : queries) {
        auto toks = split(q);
        auto cls = ai.classify(toks);
        if (cls.best.empty()) {
            printf("  '%s' -> unknown material\n", q.c_str());
            continue;
        }
        auto it = material_to_obj.find(cls.best);
        if (it == material_to_obj.end()) {
            printf("  No object for material '%s'\n", cls.best.c_str());
            continue;
        }
        auto pred = ai.predict("drop", it->second);
        printf("  '%s' -> %s (conf=%.2f)\n", q.c_str(), pred.success ? "break" : "survive", pred.conf);
    }
}

