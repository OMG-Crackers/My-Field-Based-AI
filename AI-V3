struct MatDef {
    const char* name; float r,g,b,shine,tex,transp; bool round; int sz;
    float dens,yld,ult,E,elim,wall,fric,rough,snd,cor,temp;
};
MatDef MATS[] = {
    {"glass",0.8f,0.9f,0.95f,0.9f,0,0.6f,1,10,2.5f,30,40,70,0.001f,2,0.2f,0,4000,0.65f,18},
    {"rubber",0.9f,0.2f,0.2f,0.1f,0.4f,0,1,10,1.1f,5,15,0.05f,0.5f,10,0.9f,0.6f,500,0.8f,24},
    {"wood",0.55f,0.35f,0.2f,0.1f,0.6f,0,0,11,0.6f,40,80,12,0.01f,10,0.45f,0.5f,800,0.35f,23},
    {"metal",0.75f,0.75f,0.8f,0.85f,0,0,0,10,7.8f,250,400,200,0.002f,3,0.22f,0.1f,3000,0.35f,16},
};
const int N_MATS = 4;
PhysObj make_obj(int id, std::mt19937& rng) {
    PhysObj o; int mi=rng()%N_MATS; auto& m=MATS[mi];
    o.name = std::string(m.name)+"_"+std::to_string(id); o.material=m.name;
    std::normal_distribution<float> cn(0,0.08f);
    o.r=std::clamp(m.r+cn(rng),0.f,1.f); o.g=std::clamp(m.g+cn(rng),0.f,1.f); o.b=std::clamp(m.b+cn(rng),0.f,1.f);
    o.shine=m.shine; o.tex=m.tex; o.transp=m.transp; o.round=m.round; o.size=m.sz+(rng()%3-1);
    o.dens=m.dens; o.yld=m.yld; o.ult=m.ult; o.E=m.E; o.elim=m.elim; o.wall=m.wall;
    o.fric=m.fric; o.rough=m.rough; o.snd=m.snd; o.cor=m.cor; o.temp=m.temp;
    return o;
}
// Image rendering (simplified)
void Image::circle(int cx,int cy,int rad,float r,float g,float b,float a) {
    for(int y=0;y<IMG_H;++y) for(int x=0;x<IMG_W;++x) {
        float dx=x-cx,dy=y-cy;
        if(dx*dx+dy*dy<=rad*rad) {
            px[y][x].r=px[y][x].r*(1-a)+r*a;
            px[y][x].g=px[y][x].g*(1-a)+g*a;
            px[y][x].b=px[y][x].b*(1-a)+b*a;
        }
    }
}
void Image::rect(int x0,int y0,int x1,int y1,float r,float g,float b,float a) {
    for(int y=std::max(0,y0);y<std::min(IMG_H,y1);++y) for(int x=std::max(0,x0);x<std::min(IMG_W,x1);++x) {
        px[y][x].r=px[y][x].r*(1-a)+r*a;
        px[y][x].g=px[y][x].g*(1-a)+g*a;
        px[y][x].b=px[y][x].b*(1-a)+b*a;
    }
}
void Image::highlight(int cx,int cy,int rad,float intens) {
    for(int y=0;y<IMG_H;++y) for(int x=0;x<IMG_W;++x) {
        float dx=x-cx,dy=y-cy,d2=dx*dx+dy*dy;
        if(d2<rad*rad) { float f=1-std::sqrt(d2)/rad; float b=f*f*intens;
            px[y][x].r=std::min(1.f,px[y][x].r+b);
            px[y][x].g=std::min(1.f,px[y][x].g+b);
            px[y][x].b=std::min(1.f,px[y][x].b+b);
        }
    }
}
void Image::noise(std::mt19937& rng,float amt) {
    std::normal_distribution<float> n(0,amt);
    for(int y=0;y<IMG_H;++y) for(int x=0;x<IMG_W;++x) {
        px[y][x].r=std::clamp(px[y][x].r+n(rng),0.f,1.f);
        px[y][x].g=std::clamp(px[y][x].g+n(rng),0.f,1.f);
        px[y][x].b=std::clamp(px[y][x].b+n(rng),0.f,1.f);
    }
}
Image PhysObj::render(std::mt19937& rng) const {
    Image img; img.clear(0.4f,0.4f,0.45f);
    int cx=IMG_W/2,cy=IMG_H/2; float a=1-transp*0.7f;
    if(round) img.circle(cx,cy,size,r,g,b,a);
    else img.rect(cx-size,cy-size*2/3,cx+size,cy+size*2/3,r,g,b,a);
    if(shine>0.3f) img.highlight(cx-size/3,cy-size/3,size/2,shine);
    img.noise(rng,0.03f);
    return img;
}

